{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hand-off.to/schemas/connector.schema.json",
  "title": "Handoff connector manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["key", "family", "version", "name", "type", "status", "definition"],
  "properties": {
    "key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "family": {"const": "mcp"},
    "version": {"type": "integer", "minimum": 1},
    "display_version": {"type": "string"},
    "name": {"type": "string", "minLength": 1},
    "type": {"enum": ["mcp_stdio_container", "mcp_http_container", "mcp_http_external"]},
    "status": {"enum": ["active", "deactivated"]},
    "definition": {
      "type": "object",
      "properties": {
        "runtime": {"type": "string"},
        "command": {"type": "string"},
        "args": {"type": "array", "items": {"type": "string"}},
        "env_names": {"type": "array", "items": {"type": "string"}},
        "url": {"type": "string"},
        "headers": {"type": "object"},
        "inputs": {"type": "array", "items": {"$ref": "#/$defs/input"}},
        "instruction_template": {"type": "string"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"enum": ["mcp_stdio_container", "mcp_http_container"]}}, "required": ["type"]},
      "then": {"properties": {"definition": {"required": ["runtime"]}}}
    },
    {
      "if": {"properties": {"type": {"const": "mcp_http_external"}}, "required": ["type"]},
      "then": {"properties": {"definition": {"required": ["url"]}}}
    },
    {
      "properties": {
        "definition": {
          "required": ["doc_url"],
          "properties": {
            "doc_url": {"type": "string", "pattern": "^https?://"},
            "credential": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label"],
              "properties": {
                "label": {"type": "string"},
                "description": {"type": "string"},
                "required": {"type": "boolean"}
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "label": {"type": "string"},
        "description": {"type": "string"},
        "default": {"type": "string"},
        "env": {"type": "boolean"},
        "required": {"type": "boolean"}
      }
    }
  }
}
