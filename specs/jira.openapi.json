{
  "openapi": "3.0.0",
  "paths": {
    "/rest/api/3/search": {
      "get": {
        "operationId": "search_issues",
        "summary": "Search issues (JQL)",
        "parameters": [
          {
            "name": "jql",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/rest/api/3/issue/{issueIdOrKey}": {
      "get": {
        "operationId": "get_issue",
        "summary": "Get issue",
        "parameters": [
          {
            "name": "issueIdOrKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
